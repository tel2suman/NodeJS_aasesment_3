<%- include('layouts/header') %>

    <%- include('layouts/nav') %>

    <div class="container mt-5">
        <div class="row">
            <div class="col-lg-12">
                <!-- Post content-->
                <article>
                    <!-- Post header-->
                    <header class="mb-4">
                        <!-- Post title-->
                        <h1 class="fw-bolder mb-1">
                            <%= data.title %>
                        </h1>
                        <!-- Post meta content-->
                        <div class="text-muted fst-italic mb-2">Posted on <%= new Date(data.createdAt).toDateString() %>
                        </div>
                    </header>
                    <!-- Preview image figure-->
                    <figure class="mb-4">
                        <% if(data.cover_image){ %>
                            <img src="<%= data.cover_image %>" class="img-fluid rounded w-100" alt="..." />
                            <% } %>
                    </figure>
                    <!-- Post content-->
                    <section class="mb-5">
                        <p class="fs-5 mb-4">
                            <%= data.content %>.
                        </p>
                    </section>
                </article>
            </div>
        </div>
    </div>


    <%- include('layouts/footer') %>